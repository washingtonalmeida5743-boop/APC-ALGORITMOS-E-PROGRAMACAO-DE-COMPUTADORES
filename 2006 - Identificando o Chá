#include <stdio.h>

int main() {
    int T, guess, correct_count = 0;

    if (scanf("%d", &T) != 1) return 0;
    for (int i = 0; i < 5; i++) {
        scanf("%d", &guess);
        
        if (guess == T) {
            correct_count++;
        }
    }

    printf("%d\n", correct_count);

    return 0;
}
