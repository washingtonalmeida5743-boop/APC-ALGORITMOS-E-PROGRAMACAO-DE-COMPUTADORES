#include <stdio.h>
int volter(int y){
if(y == 0)return 0;
if(y== 1)return 1;
int a=0;
int b=1;
int soma;
for(int k = 2; k <= y;k++){
    soma = a+b;
    a = b;
    b= soma;
}
return b;
}

int main() {
int n;
scanf("%d", &n);
for(int y = 0; y < n; y++){
    printf("%d", volter(y));
    if (y != n-1){
        printf(" ");
    }
}
printf("\n");
    return 0;
}
