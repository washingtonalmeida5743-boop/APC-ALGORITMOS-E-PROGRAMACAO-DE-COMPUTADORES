#include <stdio.h>

int main() {
    int Cv, Ce, Cs, Fv, Fe, Fs;
    scanf("%d %d %d %d %d %d", &Cv, &Ce, &Cs, &Fv, &Fe, &Fs);

    int pontos_C = Cv * 3 + Ce;
    int pontos_F = Fv * 3 + Fe;

    if (pontos_C > pontos_F) {
        printf("C\n");
    } else if (pontos_C < pontos_F) {
        printf("F\n");
    } else {
        if (Cs > Fs) {
            printf("C\n");
        } else if (Cs < Fs) {
            printf("F\n");
        } else {
            printf("=\n");
        }
    }

    return 0;
}
